# Puerto del servidor
PORT=4000

# Orígenes permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:5173,https://tu-app.vercel.app

# Google Sheets
GOOGLE_SHEET_ID=pega_aqui_el_id_de_la_hoja
GOOGLE_SHEET_RANGE=Solicitudes!A:AB

# Google Drive (vía Apps Script puente)
GOOGLE_DRIVE_FOLDER_ID=pega_aqui_el_id_de_la_carpeta
APPS_SCRIPT_URL=https://script.google.com/macros/s/.../exec
APPS_SCRIPT_SECRET=token_largo_aleatorio

# Opcional: copia interna a la Muni en cada correo
MUNI_EMAIL_CC=

# reCAPTCHA v2 (checkbox "No soy un robot")
# Obtén las keys en: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=tu_secret_key_aqui

# Solo desarrollo (NUNCA en producción): salta verificación de reCAPTCHA
# RECAPTCHA_BYPASS=1
